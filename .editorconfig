root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{xml,svg,blp,ui}]
indent_size = 2

[Makefile]
indent_style = tab

[PKGBUILD]
indent_size = 2
