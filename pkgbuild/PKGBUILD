# Maintainer: Leonardo Athayde <leoathayde@gmail.com>
# Contributor: Bruno Goncalves <bigbruno@gmail.com>

pkgname=bigiris
pkgver=0.1.0
pkgrel=1
arch=('x86_64')
license=('GPL-3.0-or-later')
url="https://github.com/xathay/bigiris"
pkgdesc="Visualizador e conversor de imagens moderno, com integração ao gerenciador de arquivos"
depends=(
  'gcc-libs'
  'glibc'
  'gtk4'
  'libadwaita'
  'dav1d'            # decodificador AVIF
  'openssl'          # TLS para download de modelos IA (ureq + native-tls)
  'onnxruntime'      # IA (remove-bg via BiRefNet); embutida no binario
  'hicolor-icon-theme'
)
optdepends=(
  'libvips: backend de batch para milhares de arquivos'
  'libheif: suporte a HEIC/HEIF (Tier 2, quando habilitado)'
  'libjxl: suporte a JPEG XL (Tier 2, quando habilitado)'
  'nautilus-python: integração top-level no Nautilus'
  'dolphin: integração no gerenciador Dolphin (KDE)'
  'nautilus: integração no gerenciador Nautilus (GNOME)'
  'nemo: integração no gerenciador Nemo (Cinnamon)'
  'thunar: integração no gerenciador Thunar (XFCE)'
  'pcmanfm-qt: integração no gerenciador PCManFM-Qt (LXQt)'
  'io.elementary.files: integração no gerenciador Files (elementary)'
)
makedepends=('rust' 'cargo' 'git' 'pkgconf' 'gettext')
# Disable LTO. Arch's default makepkg env appends `-flto=auto` to CFLAGS
# and `-C linker-plugin-lto` to RUSTFLAGS, which makes cc-rs emit pure
# LTO bitcode for libmimalloc-sys's static.o. Without an LLVM gold/LTO
# plugin loaded into the linker (bfd or rust-lld), every `mi_*` symbol
# shows up undefined at the final link. Confirmed against the leaner
# archlinux:latest CI image; some user setups can hit it too. We keep
# -O3 and the mimalloc batch perf win without LTO.
options=('!lto')
source=("git+https://github.com/xathay/bigiris.git")
sha256sums=('SKIP')
install="$pkgname.install"

prepare() {
  cd "$pkgname"
  # blueprint-compiler entra quando a GUI ganhar arquivos .blp.
  true
}

build() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR="$srcdir/target"
  # `--features "gui ai"` compila o visualizador GTK4 / libadwaita e os
  # diálogos de IA (remover fundo via BiRefNet, upscale Lanczos3) dentro
  # do mesmo binario `bigiris` (arquitetura single-binary).
  cargo build --locked --release --features "gui ai" --package bigiris

  # Compila os catalogos de traducao listados em data/po/LINGUAS.
  # msgfmt -> .mo binario; package() instala em /usr/share/locale/<lang>/.
  while read -r lang; do
    [[ -z "$lang" || "$lang" == \#* ]] && continue
    msgfmt -o "data/po/${lang}.mo" "data/po/${lang}.po"
  done < data/po/LINGUAS
}

check() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR="$srcdir/target"
  cargo test --locked --release --workspace
  "$CARGO_TARGET_DIR/release/bigiris" --self-test
}

package() {
  cd "$pkgname"

  # Binario
  install -Dm755 "$srcdir/target/release/bigiris" \
    "$pkgdir/usr/bin/bigiris"

  # Reverse-DNS IDs (necessarios para Flathub / GNOME Circle; aceitos pelo BigLinux)
  install -Dm644 "data/com.biglinux.Iris.desktop" \
    "$pkgdir/usr/share/applications/com.biglinux.Iris.desktop"
  install -Dm644 "data/com.biglinux.Iris.metainfo.xml" \
    "$pkgdir/usr/share/metainfo/com.biglinux.Iris.metainfo.xml"
  install -Dm644 "data/com.biglinux.Iris.gschema.xml" \
    "$pkgdir/usr/share/glib-2.0/schemas/com.biglinux.Iris.gschema.xml"
  install -Dm644 "data/icons/hicolor/scalable/apps/com.biglinux.Iris.svg" \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/com.biglinux.Iris.svg"

  # Documentacao / licenca
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

  # Catalogos de traducao compilados em build().
  while read -r lang; do
    [[ -z "$lang" || "$lang" == \#* ]] && continue
    install -Dm644 "data/po/${lang}.mo" \
      "$pkgdir/usr/share/locale/${lang}/LC_MESSAGES/$pkgname.mo"
  done < data/po/LINGUAS

  # Service menus system-wide: o proprio binario gera e coloca os arquivos
  # sob $pkgdir/usr/share/... e $pkgdir/etc/xdg/... para os seis
  # gerenciadores suportados. Usuarios nao precisam rodar
  # `install-integrations --user` apos instalar o pacote.
  "$srcdir/target/release/bigiris" install-integrations --system \
    --destdir="$pkgdir"
}
